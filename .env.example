# ローカル開発では何も設定しなくても動きます（PGlite + MockAI + フルPlaywright）。
# 本番（Vercel など）では以下を設定してください。

# 実 PostgreSQL（未設定ならローカルは PGlite を使用）
# 例: Vercel Postgres / Neon の接続文字列
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# 実 AI プロバイダ（Claude）を使う場合
# AI_PROVIDER=real
# ANTHROPIC_API_KEY=sk-ant-...

# Vercel のビルド時に full playwright のブラウザDLをスキップ（推奨）
# PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
